# ─────────────────────────────────────────────
# DentFlow — Environment Configuration
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dentflow

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (for BullMQ / Automation)
REDIS_HOST=localhost
REDIS_PORT=6379

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Application
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
